---
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-dots"></div>
  </div>
  <div class="container">
    <div class="hero-badge">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
      </svg>
      v0.1.0 Now Available
    </div>
    <img src="/images/logo.png" alt="Rep-li-bot" class="hero-logo" />
    <h1>Build Private Apps<br/><span class="gradient-text">with AI</span></h1>
    <p class="hero-subtitle">
      A local-first desktop application that transforms plain English descriptions into working apps and widgets — all on your machine, completely private.
    </p>
    <div class="hero-actions">
      <a href="/download" class="btn btn-primary btn-lg">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="7,10 12,15 17,10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download for Windows
      </a>
      <a href="/docs/getting-started" class="btn btn-secondary btn-lg">Read the Docs</a>
    </div>
    <div class="hero-meta">
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        Windows 10+ required
      </span>
      <span class="separator">|</span>
      <span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
          <polyline points="22,4 12,14.01 9,11.01"/>
        </svg>
        ~86 MB installer
      </span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    text-align: center;
    padding: var(--space-24) 0 var(--space-16);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-gradient {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse at center, rgba(61, 139, 110, 0.08) 0%, rgba(249, 115, 22, 0.04) 40%, transparent 70%);
    pointer-events: none;
  }

  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(61, 139, 110, 0.08) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }

  .hero-logo {
    height: 100px;
    width: auto;
    max-width: 320px;
    margin: 0 auto var(--space-6);
    display: block;
    object-fit: contain;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: linear-gradient(135deg, var(--primary) 0%, rgba(74, 222, 154, 0.15) 100%);
    color: var(--primary-dark);
    padding: var(--space-2) var(--space-4);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: var(--space-8);
    border: 1px solid rgba(61, 139, 110, 0.2);
  }

  h1 {
    font-size: 4rem;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: var(--space-6);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto var(--space-8);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    margin-bottom: var(--space-8);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: 1.125rem;
  }

  .hero-meta {
    color: var(--text-dim);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
  }

  .hero-meta span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .separator {
    opacity: 0.4;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.75rem;
    }

    .hero-logo {
      height: 80px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .btn-lg {
      width: 100%;
      max-width: 280px;
    }
  }
</style>