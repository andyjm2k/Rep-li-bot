---
const steps = [
  {
    number: '01',
    title: 'Describe Your App',
    description: 'Tell Rep-li-bot what you want in plain English. A productivity tracker, a recipe manager, a widget for your smart home.',
  },
  {
    number: '02',
    title: 'AI Generates the Code',
    description: 'Rep-li-bot uses AI to understand your requirements and generates working code tailored to your needs.',
  },
  {
    number: '03',
    title: 'Run Locally',
    description: 'Preview and run your app instantly. Everything stays on your machine, private and secure.',
  },
];
---

<section class="how-it-works">
  <div class="container">
    <div class="section-header">
      <h2>How It Works</h2>
      <p>From idea to running app in three simple steps.</p>
    </div>
    <div class="steps">
      {steps.map((step, index) => (
        <div class="step">
          <div class="step-number">{step.number}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
          {index < steps.length - 1 && (
            <div class="step-connector">
              <svg width="40" height="24" viewBox="0 0 40 24" fill="none">
                <path d="M0 12h32M24 12l8-6v12l-8-6z" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: var(--space-24) 0;
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-header h2 {
    margin-bottom: var(--space-4);
  }

  .section-header p {
    font-size: 1.125rem;
    color: var(--text-muted);
  }

  .steps {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: var(--space-6);
    max-width: 1100px;
    margin: 0 auto;
  }

  .step {
    flex: 1;
    text-align: center;
    position: relative;
    padding: 0 var(--space-6);
    max-width: 300px;
  }

  .step-number {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    font-size: 1.5rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-6);
    box-shadow: 0 4px 16px rgba(61, 139, 110, 0.3);
    letter-spacing: 0.05em;
  }

  .step h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-3);
    color: var(--text);
  }

  .step p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .step-connector {
    position: absolute;
    top: 36px;
    right: -20px;
    color: var(--primary);
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .steps {
      flex-direction: column;
      gap: var(--space-12);
      align-items: center;
    }

    .step {
      max-width: 320px;
    }

    .step-connector {
      display: none;
    }
  }
</style>